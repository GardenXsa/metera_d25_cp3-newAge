    "ui_runtime": {
      "path": "./data/ui_runtime.json",
      "default_type": "object",
      "merge_policy": "deepMerge"
    },
    "prompt_runtime": {
      "path": "./data/prompt_runtime.json",
      "default_type": "object",
      "merge_policy": "deepMerge"
    },
    "gameplay_runtime": {
      "path": "./data/gameplay_runtime.json",
      "default_type": "object",
      "merge_policy": "deepMerge"
    },
    "building_types": {
