{
  "schemaVersion": 1,
  "contracts": {
    "items": {
      "required_fields": [
        "basePrice",
        "category",
        "tags"
      ],
      "canonical_tag_source": "tag_defaults.json"
    }
  },
  "modding_contract": {
    "schema_version": 1,
    "base_game_mod_id": "base_game",
    "descriptor_defaults": {
      "owner": "base_game",
      "source": "base_data",
      "required": true
    },
    "total_conversion": {
      "skip_base_database_files_by_default": true,
      "allowed_base_passthrough_keys": [
        "eras",
        "tag_defaults",
        "classes"
      ],
      "required_database_keys": [
        "items",
        "eras",
        "classes",
        "races",
        "biomes",
        "world_config",
        "tag_defaults"
      ]
    },
    "merge_policies": [
      "deepMerge",
      "append",
      "appendUnique",
      "upsertById",
      "replace"
    ]
  },
  "database_files": {
    "items": {
      "path": "./data/economy_items.json",
      "default_type": "object",
      "merge_policy": "deepMerge",
      "key_aliases": [
        "economy_items"
      ],
      "replace_on_total_conversion": true
    },
    "recipes": {
      "path": "./data/economy_recipes.json",
      "default_type": "array",
      "merge_policy": "append",
      "key_aliases": [
        "economy_recipes"
      ],
      "replace_on_total_conversion": true
    },
    "facilities": {
      "path": "./data/facility_names.json",
      "default_type": "object",
      "merge_policy": "deepMerge",
      "key_aliases": [
        "facility_names"
      ],
      "replace_on_total_conversion": true
    },
    "eras": {
      "path": "./data/eras.json",
      "default_type": "array",
      "merge_policy": "upsertById",
      "replace_on_total_conversion": true
    },
    "classes": {
      "path": "./data/classes.json",
      "default_type": "array",
      "merge_policy": "upsertById",
      "replace_on_total_conversion": true
    },
    "biomes": {
      "path": "./data/biomes.json",
      "default_type": "array",
      "merge_policy": "upsertById"
    },
    "city_gen": {
      "path": "./data/city_gen.json",
      "default_type": "object",
      "merge_policy": "deepMerge"
    },
    "monsters": {
      "path": "./data/monsters.json",
      "default_type": "array",
      "merge_policy": "upsertById"
    },
    "disasters": {
      "path": "./data/disasters.json",
      "default_type": "array",
      "merge_policy": "upsertById"
    },
    "races": {
      "path": "./data/races.json",
      "default_type": "array",
      "merge_policy": "upsertById"
    },
    "professions": {
      "path": "./data/professions.json",
      "default_type": "array",
      "merge_policy": "upsertById"
    },
    "traits": {
      "path": "./data/traits.json",
      "default_type": "array",
      "merge_policy": "upsertById"
    },
    "npc_names": {
      "path": "./data/npc_names.json",
      "default_type": "object",
      "merge_policy": "deepMerge"
    },
    "faction_relations": {
      "path": "./data/faction_relations.json",
      "default_type": "object",
      "merge_policy": "deepMerge"
    },
    "world_config": {
      "path": "./data/world_config.json",
